#include <stdio.h>

int main(){

    int numero1, numero2;

    printf("Digite o primeiro número: "); 
    scanf("%d", &numero1); 
    
    printf("Digite o segundo número: "); 
    scanf("%d", &numero2); 

    int soma, sub, mult;
    float divi;
    

    soma = numero1 + numero2; 
    sub  = numero1 - numero2; 
    mult = numero1 * numero2; 
    divi = (float) numero1 / numero2; 

    printf("Soma: %d\n", soma); 
    printf("Subtração: %d\n", sub); 
    printf("Multiplicação: %d\n", mult); 
    printf("Divisão: %.2f\n", divi); 

    return 0;


}